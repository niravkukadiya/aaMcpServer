<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>

  <appSettings>
    <add key="Http.Prefix" value="http://+:8080/" />
    <add key="Http.McpPath" value="/mcp" />

    <add key="Historian.Server" value="localhost" />
    <add key="Historian.Database" value="Runtime" />
    <add key="Historian.User" value="aaUser" />
    <add key="Historian.Password" value="aaPassword" />
    <add key="Historian.CommandTimeoutSeconds" value="60" />
    <add key="Historian.ExtraConnectionOptions" value="Encrypt=False;TrustServerCertificate=True" />
    <!-- Treat unspecified-kind DateTime values from the Historian as UTC.
         Default false = treat them as local time (typical for Wonderware). -->
    <add key="Historian.TimesAreUtc" value="false" />

    <add key="Alarms.Source" value="v_AlarmEventHistory" />
    <add key="Alarms.TimeColumn" value="EventStamp" />

    <add key="Limits.MaxRows" value="5000" />

    <!-- Default output format for HIS tools. "compact" = token-efficient
         (epoch_ms timestamps, columnar header, constant columns dropped).
         "table" = verbose pipe-table (older format, easier to eyeball). -->
    <add key="Output.Format" value="compact" />

    <add key="Log.Directory" value="logs" />
    <add key="Log.FilePrefix" value="mcp-server" />
    <add key="Log.RotationHours" value="6" />
    <add key="Log.RetentionDays" value="7" />
    <add key="Log.MinLevel" value="INFO" />

    <add key="Galaxy.Enabled" value="false" />
    <add key="Galaxy.Node" value="GALAXYSVR" />
    <add key="Galaxy.Name" value="MyGalaxy" />
    <add key="Galaxy.User" value="DefaultUser" />
    <add key="Galaxy.Password" value="" />
    <add key="Galaxy.ProgIds" value="ArchestrA.GRAccessApp,ArchestrA.GRAccessApp.4,ArchestrA.GRAccessApp.5,ArchestrA.GRAccessApp.6" />
  </appSettings>
</configuration>
